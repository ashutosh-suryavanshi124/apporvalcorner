<mvc:View
    controllerName="approvalcorner.controller.Main"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m">
<Page class="sapUiContentPadding" showHeader="false" enableScrolling="true">
    <content>

        <VBox class="sapUiMediumMarginBottom">

            <!-- Top Row -->
            <HBox
                justifyContent="SpaceBetween"
                alignItems="Center"
                width="100%"
                class="headerRow">

                <Image
                    src="images/reviewnow-logo.svg"
                    height="2.75rem"
                    densityAware="false"
                    class="reviewNowLogo"/>

                <Button
                    icon="sap-icon://log"
                    text="Logout"
                    press="onLogout"
                    type="Transparent"/>

            </HBox>

            <!-- Page Title -->
            <Title
                text="{main>/pageTitle}"
                level="H3"
                class="sapUiTinyMarginTop headerRow"/>

        </VBox>
			<IconTabBar
                select="onTabSelect"
                selectedKey="{main>/selectedKey}">
				<!-- New -->
				<items>
					<IconTabFilter
                        key="New"
                        text="{= 'New (' + (${main>/NewCount} || 0) + ')' }">
						<Table
                            id="newTable"
                            inset="false"
                            growing="true"
                            growingThreshold="50"
                            growingScrollToLoad="true"
                            items="{main>/New}"
                            mode="MultiSelect">
							<columns>
								<Column hAlign="Center">
									<Text text="Connector"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Job ID"/>
								</Column>
								<Column hAlign="Center">
									<Text text="User Name"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Job Name"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Fiscal Year"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Fiscal Quarter"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Review Type"/>
								</Column>
								<Column hAlign="Center">
									<Text text="No. of Roles"/>
								</Column>
							</columns>
							<items>
								<ColumnListItem vAlign="Middle">
									<cells>
										<Text text="{main>CONNECTOR}"/>
										<Text text="{main>JOB_ID}"/>
										<Text text="{main>EUSER}"/>
										<Text text="{main>JobName}"/>
										<Text text="{main>ATT_FISCAL}"/>
										<Text text="{main>ATT_QUARTERLY}"/>
										<Text text="{main>REVIEW_TYPE}"/>
										<Text text="{main>RCount}"/>
									</cells>
								</ColumnListItem>
							</items>
						</Table>
					</IconTabFilter>
					<!-- In Progress -->
					<IconTabFilter
                        key="InProgress"
                        text="{= 'In Progress (' + (${main>/InProgressCount} || 0) + ')' }">
						<Table
                            id="inProgressTable"
                            inset="false"
                            growing="true"
                            growingThreshold="50"
                            growingScrollToLoad="true"
                            items="{main>/InProgress}"
                            mode="MultiSelect">
							<columns>
								<Column hAlign="Center">
									<Text text="Connector"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Job ID"/>
								</Column>
								<Column hAlign="Center">
									<Text text="User Name"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Job Name"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Fiscal Year"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Fiscal Quarter"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Review Type"/>
								</Column>
								<Column hAlign="Center">
									<Text text="No. of Roles"/>
								</Column>
							</columns>
							<items>
								<ColumnListItem vAlign="Middle">
									<cells>
										<Text text="{main>CONNECTOR}"/>
										<Text text="{main>JOB_ID}"/>
										<Text text="{main>EUSER}"/>
										<Text text="{main>JobName}"/>
										<Text text="{main>ATT_FISCAL}"/>
										<Text text="{main>ATT_QUARTERLY}"/>
										<Text text="{main>REVIEW_TYPE}"/>
										<Text text="{main>RCount}"/>
									</cells>
								</ColumnListItem>
							</items>
						</Table>
					</IconTabFilter>
					<!-- Closed -->
					<IconTabFilter
                        key="Closed"
                        text="{= 'Closed (' + (${main>/ClosedCount} || 0) + ')' }">
						<Table
                            id="closedTable"
                            inset="false"
                            growing="true"
                            growingThreshold="50"
                            growingScrollToLoad="true"
                            items="{main>/Closed}"
                            mode="MultiSelect">
							<columns>
								<Column hAlign="Center">
									<Text text="Connector"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Job ID"/>
								</Column>
								<Column hAlign="Center">
									<Text text="User Name"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Job Name"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Fiscal Year"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Fiscal Quarter"/>
								</Column>
								<Column hAlign="Center">
									<Text text="Review Type"/>
								</Column>
								<Column hAlign="Center">
									<Text text="No. of Roles"/>
								</Column>
							</columns>
							<items>
								<ColumnListItem vAlign="Middle">
									<cells>
										<Text text="{main>CONNECTOR}"/>
										<Text text="{main>JOB_ID}"/>
										<Text text="{main>EUSER}"/>
										<Text text="{main>JobName}"/>
										<Text text="{main>ATT_FISCAL}"/>
										<Text text="{main>ATT_QUARTERLY}"/>
										<Text text="{main>REVIEW_TYPE}"/>
										<Text text="{main>RCount}"/>
									</cells>
								</ColumnListItem>
							</items>
						</Table>
					</IconTabFilter>
				</items>
			</IconTabBar>
		</content>
	</Page>
</mvc:View>