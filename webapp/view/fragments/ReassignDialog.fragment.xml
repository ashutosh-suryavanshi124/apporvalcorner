<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="reassignDialog"
        title="Reassign"
        icon="sap-icon://add-employee"
        draggable="true"
        resizable="true"
        contentWidth="500px">
        <content>
            <VBox class="sapUiMediumMargin">
                <Label
                    text="Reviewer Name"
                    required="true"/>
                <Input
                    value="{reassign>/reviewer}"
                    placeholder="Enter Reviewer Name"/>
                <Label
                    text="Reason / Comments"
                    required="true"
                    class="sapUiSmallMarginTop"/>
                <TextArea
                    rows="4"
                    width="100%"
                    value="{reassign>/reason}"
                    placeholder="Enter Reason"/>
            </VBox>
        </content>
        <beginButton>
            <Button
                text="Reassign"
                type="Accept"
                press="onReassignConfirm"/>
        </beginButton>
        <endButton>
            <Button
                text="Cancel"
                press="onReassignCancel"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>